{
  "name": "file-tag",
  "displayName": "File Tag",
  "description": "Tag files with glob patterns and create filtered views with logical conditions",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:fileTagView"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fileTagContainer",
          "title": "File Tag",
          "icon": "media/tag.svg"
        }
      ]
    },
    "views": {
      "fileTagContainer": [
        {
          "id": "fileTagView",
          "name": "File Tag"
        }
      ]
    },
    "commands": [
      {
        "command": "fileTag.openView",
        "title": "File Tag: Open View"
      },
      {
        "command": "fileTag.createTag",
        "title": "File Tag: Create Tag"
      },
      {
        "command": "fileTag.addFiles",
        "title": "File Tag: Add Files to Tag"
      },
      {
        "command": "fileTag.selectView",
        "title": "File Tag: Select View",
        "icon": "$(filter)"
      },
      {
        "command": "fileTag.searchInView",
        "title": "File Tag: Search in View",
        "icon": "$(search)"
      },
      {
        "command": "fileTag.newView",
        "title": "File Tag: New View from Tags",
        "icon": "$(add)"
      },
      {
        "command": "fileTag.openConfig",
        "title": "File Tag: Open Config",
        "icon": "$(gear)"
      },
      {
        "command": "fileTag.refreshView",
        "title": "File Tag: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "fileTag.deleteView",
        "title": "File Tag: Delete View",
        "icon": "$(trash)"
      },
      {
        "command": "fileTag.clearLastView",
        "title": "File Tag: Clear Last View (Dev)"
      },
      {
        "command": "fileTag.openToSide",
        "title": "Open to the Side"
      },
      {
        "command": "fileTag.revealInExplorer",
        "title": "Reveal in Explorer View"
      },
      {
        "command": "fileTag.revealInOS",
        "title": "Reveal in File Explorer"
      },
      {
        "command": "fileTag.openInTerminal",
        "title": "Open in Integrated Terminal"
      },
      {
        "command": "fileTag.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "fileTag.copyRelativePath",
        "title": "Copy Relative Path"
      },
      {
        "command": "fileTag.copyFile",
        "title": "Copy"
      },
      {
        "command": "fileTag.pasteFile",
        "title": "Paste"
      },
      {
        "command": "fileTag.duplicateFile",
        "title": "Duplicate"
      },
      {
        "command": "fileTag.renameFile",
        "title": "Rename..."
      },
      {
        "command": "fileTag.deleteFile",
        "title": "Delete",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "fileTag.selectView",
          "when": "view == fileTagView",
          "group": "navigation@1"
        },
        {
          "command": "fileTag.newView",
          "when": "view == fileTagView && fileTag.selectingView",
          "group": "navigation@2"
        },
        {
          "command": "fileTag.searchInView",
          "when": "view == fileTagView && !fileTag.selectingView",
          "group": "navigation@3"
        },
        {
          "command": "fileTag.refreshView",
          "when": "view == fileTagView",
          "group": "navigation@4"
        },
        {
          "command": "fileTag.openConfig",
          "when": "view == fileTagView",
          "group": "navigation@5"
        }
      ],
      "view/item/context": [
        {
          "command": "fileTag.deleteView",
          "when": "view == fileTagView && viewItem == fileTagViewListItem",
          "group": "inline"
        },
        {
          "command": "fileTag.openToSide",
          "when": "view == fileTagView && viewItem == fileTagFile",
          "group": "navigation@1"
        },
        {
          "command": "fileTag.revealInExplorer",
          "when": "view == fileTagView && (viewItem == fileTagFile || viewItem == fileTagDir)",
          "group": "navigation@2"
        },
        {
          "command": "fileTag.revealInOS",
          "when": "view == fileTagView && (viewItem == fileTagFile || viewItem == fileTagDir)",
          "group": "navigation@3"
        },
        {
          "command": "fileTag.openInTerminal",
          "when": "view == fileTagView && (viewItem == fileTagFile || viewItem == fileTagDir)",
          "group": "2_workspace@1"
        },
        {
          "command": "fileTag.copyFile",
          "when": "view == fileTagView && (viewItem == fileTagFile || viewItem == fileTagDir)",
          "group": "5_cutcopypaste@1"
        },
        {
          "command": "fileTag.pasteFile",
          "when": "view == fileTagView && viewItem == fileTagDir && fileTag.clipboardHasFile",
          "group": "5_cutcopypaste@2"
        },
        {
          "command": "fileTag.duplicateFile",
          "when": "view == fileTagView && (viewItem == fileTagFile || viewItem == fileTagDir)",
          "group": "5_cutcopypaste@3"
        },
        {
          "command": "fileTag.copyPath",
          "when": "view == fileTagView && (viewItem == fileTagFile || viewItem == fileTagDir)",
          "group": "5_cutcopypaste@4"
        },
        {
          "command": "fileTag.copyRelativePath",
          "when": "view == fileTagView && (viewItem == fileTagFile || viewItem == fileTagDir)",
          "group": "5_cutcopypaste@5"
        },
        {
          "command": "fileTag.renameFile",
          "when": "view == fileTagView && (viewItem == fileTagFile || viewItem == fileTagDir)",
          "group": "7_modification@1"
        },
        {
          "command": "fileTag.deleteFile",
          "when": "view == fileTagView && (viewItem == fileTagFile || viewItem == fileTagDir)",
          "group": "7_modification@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "esbuild": "^0.24.0"
  }
}
